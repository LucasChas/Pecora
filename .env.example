# Copiá este archivo como .env y completá con los valores reales de tu proyecto Supabase.
# (En Supabase: Project Settings -> API)

# URL de la API del proyecto (ID del proyecto + .supabase.co)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública "anon" (es segura para el frontend: la seguridad la da RLS)
VITE_SUPABASE_ANON_KEY=

# Número de WhatsApp al que escriben los clientes, formato internacional SIN + ni espacios.
# Ejemplo Argentina: 549XXXXXXXXXX  (54 = país, 9 = celular, luego el número)
VITE_WHATSAPP_NUMBER=5490000000000

# Usuario de Instagram SIN el @ (ej: pecora.bebe). Opcional: si lo dejás vacío,
# no se muestra el botón de "Consultar por Instagram".
VITE_INSTAGRAM_USER=

# Qué vista expone el deploy. Se usa SOBRE TODO en Vercel para tener dos URLs:
#   - catalog -> muestrario público (la ruta /admin no existe en este deploy)
#   - admin   -> panel privado, servido en la raíz "/"
# En desarrollo local dejala vacía/sin definir: así tenés las dos rutas
# disponibles (/ para el catálogo y /admin para el panel).
VITE_APP_MODE=
